# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=honey
POSTGRES_PASSWORD=change_me_strong_password

# ── Zitadel ───────────────────────────────────────────────────────────────────
# Masterkey ровно 32 символа (AES-256)
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
ZITADEL_ADMIN_PASS=Admin1!Change_Me
ZITADEL_DOMAIN=auth.honeygarden.space
# OIDC client_id для портала (создать в Zitadel → Applications → New App → PKCE)
PORTAL_ZITADEL_CLIENT_ID=

# ── Wakapi ────────────────────────────────────────────────────────────────────
WAKAPI_PASSWORD_SALT=change_me_random_string
WAKAPI_OIDC_CLIENT_ID=
WAKAPI_OIDC_CLIENT_SECRET=

# ── Мониторинг ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me

# ── Forum (honeydrop) ─────────────────────────────────────────────────────────
# JWKS URL для api-gateway (внутренняя docker-сеть)
JWKS_URL=http://zitadel:8080/oauth/v2/keys
JWKS_HOST=auth.honeygarden.space
# Zitadel sub-ID пользователей с админскими правами (через запятую).
# Нужны для роутов /admin/* (добавление RSS источников и т.д.).
ADMIN_AUTH_IDS=
MEILISEARCH_API_KEY=change_me_masterkey
FRONTEND_URL=https://honeygarden.space
SENTRY_DSN=
OTEL_ENDPOINT=

# ── Git-интеграции (OAuth) ───────────────────────────────────────────────────
# Base URL, на который провайдер вернёт юзера. Должен включать /api/v1.
OAUTH_CALLBACK_BASE=https://honeygarden.space/api/v1
# Случайный секрет (>=32 байта) для подписи state-токена. openssl rand -hex 32
OAUTH_STATE_KEY=change_me_random_32_bytes_hex

# Зарегистрировать приложение → https://github.com/settings/developers
# Authorization callback URL: ${OAUTH_CALLBACK_BASE}/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Зарегистрировать приложение → https://gitlab.com/-/profile/applications
# Redirect URI: ${OAUTH_CALLBACK_BASE}/integrations/gitlab/callback
# Scopes: read_api, read_user
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://gitlab.com

# Зарегистрировать приложение → https://codeberg.org/user/settings/applications
# Redirect URI: ${OAUTH_CALLBACK_BASE}/integrations/codeberg/callback
CODEBERG_CLIENT_ID=
CODEBERG_CLIENT_SECRET=

# ── MinIO / S3 — пользовательские загрузки ────────────────────────────────────
# Bucket создаётся автоматически на старте бэкенда, public-read policy выставляется тоже.
# В production можно подменить S3_ENDPOINT на сторонний S3 (Backblaze, Cloudflare R2 и т.д.).
S3_ENDPOINT=minio:9000
S3_BUCKET=uploads
S3_ACCESS_KEY=minio_change_me
S3_SECRET_KEY=change_me_strong_minio_secret
S3_USE_SSL=false
# Базовый URL, под которым клиенту видно бакет (Caddy проксирует /uploads/* → minio:9000)
S3_PUBLIC_BASE=/uploads

# ── Caddy / домен ─────────────────────────────────────────────────────────────
# Email для Let's Encrypt (HTTP-01 challenge, работает с любым DNS провайдером)
ACME_EMAIL=admin@honeygarden.space
