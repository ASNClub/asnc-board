{
  "uid": "honeygarden-overview",
  "title": "HoneyGarden — Overview",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["honeygarden"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Backend up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up{job=\"honeygarden\"}", "refId": "A" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "RPS (5m)",
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_requests_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error rate (5xx, 5m)",
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ] }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 latency (5m)",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "p99 latency (5m)",
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "RPS by status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (status) (rate(http_requests_total[1m]))", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Latency p50/p95/p99 (overall)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Top routes by RPS",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "topk(10, sum by (path) (rate(http_requests_total[5m])))", "legendFormat": "{{path}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Top routes by p95 latency",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "topk(10, histogram_quantile(0.95, sum by (path, le) (rate(http_request_duration_seconds_bucket[5m]))))", "legendFormat": "{{path}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Response size p95 by route",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "topk(10, histogram_quantile(0.95, sum by (path, le) (rate(http_response_size_bytes_bucket[5m]))))", "legendFormat": "{{path}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Go runtime — goroutines / heap",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "go_goroutines{job=\"honeygarden\"}", "legendFormat": "goroutines", "refId": "A" },
        { "expr": "go_memstats_heap_alloc_bytes{job=\"honeygarden\"}", "legendFormat": "heap_alloc (bytes)", "refId": "B" }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Process CPU (rate) / RSS",
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(process_cpu_seconds_total{job=\"honeygarden\"}[1m])", "legendFormat": "cpu (cores)", "refId": "A" },
        { "expr": "process_resident_memory_bytes{job=\"honeygarden\"}", "legendFormat": "rss (bytes)", "refId": "B" }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Business — totals & activity",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Users",
      "gridPos": { "x": 0, "y": 37, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "hg_users_total", "refId": "A" }],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Online",
      "gridPos": { "x": 4, "y": 37, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "hg_online_users", "refId": "A" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "blue", "value": null },
        { "color": "green", "value": 1 }
      ] } } }
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Communities",
      "gridPos": { "x": 8, "y": 37, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "hg_communities_total", "refId": "A" }]
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Posts (user)",
      "gridPos": { "x": 12, "y": 37, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "hg_user_posts_total", "refId": "A" }]
    },
    {
      "id": 25,
      "type": "stat",
      "title": "Posts (RSS)",
      "gridPos": { "x": 16, "y": 37, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "hg_rss_posts_total", "refId": "A" }]
    },
    {
      "id": 26,
      "type": "stat",
      "title": "Comments",
      "gridPos": { "x": 20, "y": 37, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "hg_comments_total", "refId": "A" }]
    },
    {
      "id": 27,
      "type": "stat",
      "title": "Chat messages",
      "gridPos": { "x": 0, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "hg_chat_messages_total", "refId": "A" }]
    },
    {
      "id": 28,
      "type": "stat",
      "title": "Notifications unread",
      "gridPos": { "x": 4, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "hg_notifications_unread_total", "refId": "A" }]
    },
    {
      "id": 29,
      "type": "stat",
      "title": "New users (1h)",
      "gridPos": { "x": 8, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "increase(hg_users_registered_total[1h])", "refId": "A" }]
    },
    {
      "id": 30,
      "type": "stat",
      "title": "Posts created (1h)",
      "gridPos": { "x": 12, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(hg_posts_created_total[1h]))", "refId": "A" }]
    },
    {
      "id": 31,
      "type": "stat",
      "title": "Comments created (1h)",
      "gridPos": { "x": 16, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "increase(hg_comments_created_total[1h])", "refId": "A" }]
    },
    {
      "id": 32,
      "type": "stat",
      "title": "Votes (post+comment, 1h)",
      "gridPos": { "x": 20, "y": 41, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "increase(hg_post_votes_total[1h]) + increase(hg_comment_votes_total[1h])", "refId": "A" }]
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "User activity (rate per minute)",
      "gridPos": { "x": 0, "y": 45, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "60 * sum(rate(hg_posts_created_total[5m]))", "legendFormat": "posts/min", "refId": "A" },
        { "expr": "60 * rate(hg_comments_created_total[5m])", "legendFormat": "comments/min", "refId": "B" },
        { "expr": "60 * rate(hg_post_votes_total[5m])", "legendFormat": "post votes/min", "refId": "C" },
        { "expr": "60 * rate(hg_comment_votes_total[5m])", "legendFormat": "comment votes/min", "refId": "D" },
        { "expr": "60 * rate(hg_chat_messages_sent_total[5m])", "legendFormat": "chat msgs/min", "refId": "E" },
        { "expr": "60 * rate(hg_bookmarks_added_total[5m])", "legendFormat": "bookmarks/min", "refId": "F" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } }
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "Posts created by kind (rate)",
      "gridPos": { "x": 12, "y": 45, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "60 * rate(hg_posts_created_total[5m])", "legendFormat": "{{kind}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } }
    },
    {
      "id": 35,
      "type": "timeseries",
      "title": "Cumulative growth — users / posts / comments",
      "gridPos": { "x": 0, "y": 53, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "hg_users_total", "legendFormat": "users", "refId": "A" },
        { "expr": "hg_user_posts_total", "legendFormat": "posts", "refId": "B" },
        { "expr": "hg_comments_total", "legendFormat": "comments", "refId": "C" },
        { "expr": "hg_communities_total", "legendFormat": "communities", "refId": "D" },
        { "expr": "hg_chat_messages_total", "legendFormat": "chat msgs", "refId": "E" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } }
    }
  ]
}
